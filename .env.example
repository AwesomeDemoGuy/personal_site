# Copy to `.env` and fill in real values. The .env file is gitignored.
#
# Weather widget coordinates, keyed by the location id passed to
# <WeatherWidget location="..."/> in src/pages/about.rs. Read server-side by
# get_weather(); never exposed to the browser. Add a LAT/LON pair per location.
WEATHER_CA_LAT=0.0
WEATHER_CA_LON=0.0
WEATHER_AZ_LAT=0.0
WEATHER_AZ_LON=0.0
